NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXTAUTH_URL=http://localhost:3000
# Сгенерируй секрет через:
#   openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-via-openssl-rand-base64-32

# OAuth: ключи провайдеров настраиваются в backend/.env (Django Allauth).
# На фронте включают кнопки Google/Steam:
NEXT_PUBLIC_GOOGLE_OAUTH=true
NEXT_PUBLIC_STEAM_OAUTH=true

STEAM_API_KEY=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Аналитика (оба опциональны, работают независимо):
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YM_ID=

# Sentry (требуется npm install @sentry/nextjs перед использованием):
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# hCaptcha для регистрации (опционально):
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
